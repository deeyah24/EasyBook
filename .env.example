# EasyBook Environment Variables
# Copy this to .env and edit for production

# Flask
SECRET_KEY=change-me-to-a-long-random-string-in-production
FLASK_ENV=production

# Database (used by docker-compose)
POSTGRES_DB=easybook
POSTGRES_USER=easybook_user
POSTGRES_PASSWORD=easybook_pass

# Backend
DATABASE_URL=postgresql://easybook_user:easybook_pass@db:5432/easybook
